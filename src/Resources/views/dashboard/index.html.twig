<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloudflare Multi View - Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --glass-bg: rgba(30, 41, 59, 0.6);
            --glass-border: rgba(255, 255, 255, 0.08);
            --primary: #38bdf8;
            --secondary: #818cf8;
            --success: #34d399;
            --warning: #fbbf24;
            --danger: #f87171;
            --text-main: #f8fafc;
            --text-sub: #94a3b8;
        }

        * {
            box-sizing: border-box; margin: 0; padding: 0;
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3 { font-family: 'Outfit', sans-serif; }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
            background-image:
                radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.1) 0%, transparent 40%),
                radial-gradient(circle at 100% 100%, rgba(129, 140, 248, 0.1) 0%, transparent 40%);
        }

        /* Top Navbar Layout */
        .navbar {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            background: rgba(15, 23, 42, 0.8);
            border-bottom: 1px solid var(--glass-border);
            padding: 1.2rem 2.5%; /* 2.5% left/right = 95% content width */
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-brand {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex; align-items: center; gap: 12px;
        }

        .search-bar {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 99px;
            padding: 0.6rem 1.5rem;
            color: white;
            font-size: 0.95rem;
            width: 350px;
            transition: all 0.3s ease;
            outline: none;
        }
        .search-bar:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary);
            box-shadow: 0 0 15px rgba(56, 189, 248, 0.2);
        }

        /* Custom Dropdown */
        .custom-dropdown {
            position: relative;
            display: inline-block;
        }
        .dropdown-trigger {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 99px;
            padding: 0.6rem 1.5rem;
            padding-right: 2.8rem;
            color: white;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            min-width: 160px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
        }
        .dropdown-trigger:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary);
        }
        .dropdown-trigger .arrow {
            position: absolute;
            right: 1.2rem;
            transition: transform 0.3s ease;
            color: var(--text-sub);
        }
        .dropdown-trigger.open .arrow {
            transform: rotate(180deg);
        }
        .dropdown-menu {
            position: absolute;
            top: calc(100% + 10px);
            left: 0;
            width: 100%;
            background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.5);
            overflow: hidden;
            z-index: 1000;
            opacity: 0;
            transform: translateY(-10px);
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .dropdown-menu.show {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }
        .dropdown-item {
            padding: 0.8rem 1.5rem;
            color: var(--text-main);
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .dropdown-item:hover {
            background: rgba(56, 189, 248, 0.1);
            color: var(--primary);
        }
        .dropdown-item.active {
            color: var(--primary);
            font-weight: 600;
            background: rgba(56, 189, 248, 0.05);
        }

        .container {
            width: 95%;
            max-width: 2500px;
            margin: 0 auto;
            padding: 2rem 0;
        }

        .date-info {
            color: var(--text-sub);
            font-size: 0.9rem;
            margin-bottom: 2rem;
            display: inline-block;
            background: var(--glass-bg);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            border: 1px solid var(--glass-border);
        }

        .group-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s ease, border-color 0.3s ease;
        }
        .group-card:hover {
            border-color: rgba(56, 189, 248, 0.3);
            transform: translateY(-2px);
        }

        .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
            border-bottom: 1px solid var(--glass-border);
            padding-bottom: 1rem;
            cursor: pointer;
        }

        .group-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-main);
            display: flex; align-items: center; gap: 10px;
        }

        .badge-count {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            font-size: 0.8rem;
            padding: 0.2rem 0.6rem;
            border-radius: 99px;
            font-weight: 800;
        }

        .chevron {
            transition: transform 0.3s ease;
        }
        .chevron.rotated {
            transform: rotate(180deg);
        }


        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th {
            text-align: left;
            padding: 0.5rem;
            color: var(--text-sub);
            font-weight: 500;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--glass-border);
        }

        th.sortable {
            cursor: pointer;
            user-select: none;
            transition: color 0.2s ease;
        }

        th.sortable:hover {
            color: var(--primary);
        }

        th.sortable span {
            display: inline-block;
            margin-left: 4px;
            font-size: 1rem;
        }

        td {
            padding: 0.3rem 0.5rem;
            color: var(--text-main);
            border-bottom: 1px solid rgba(255,255,255,0.03);
            font-size: 0.95rem;
            transition: background 0.2s ease;
            overflow: visible;
        }

        tr {
            overflow: visible;
        }

        tr:hover td {
            background: rgba(255,255,255,0.03);
            z-index: 10;
            position: relative;
        }

        .metric {
            font-family: "Outfit", sans-serif;
            font-weight: 600;
            font-size: 1.1rem;
        }
        .metric.uv { color: var(--primary); }
        .metric.req { color: var(--secondary); }
        .metric.threats { color: var(--danger); }

        .empty-state {
            text-align: center;
            padding: 4rem;
            color: var(--text-sub);
        }

        /* Toggle Switch */
        .switch-container {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.05);
            padding: 0.5rem 1rem;
            border-radius: 99px;
            border: 1px solid var(--glass-border);
        }
        .switch {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 20px;
        }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(255, 255, 255, 0.1);
            transition: .4s;
            border-radius: 20px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 14px; width: 14px;
            left: 3px; bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--primary); }
        input:checked + .slider:before { transform: translateX(20px); }

        .chart-row td {
            border-bottom: 2px solid rgba(56, 189, 248, 0.1);
            padding: 0 2rem 1.5rem 2rem;
            background: rgba(255, 255, 255, 0.01);
        }
        .chart-container {
            height: 160px; /* Slightly increased */
            width: 100%;
            position: relative;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
            padding: 8px;
            display: flex;
            align-items: center;
            transition: z-index 0.2s step-start;
            z-index: 1;
        }
        .chart-container:hover {
            z-index: 100;
        }
        tr:hover .chart-container {
            z-index: 100;
        }

        /* Animations */
        [x-cloak] { display: none !important; }

        /* Domain blur mode */
        .domain-name {
            transition: filter 0.3s ease;
        }
        .domain-name.blurred {
            filter: blur(8px);
            user-select: none;
        }


        /* HTML Tooltip Styling */
        #chartjs-tooltip {
            opacity: 0;
            position: absolute;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            color: white;
            border-radius: 12px;
            pointer-events: none;
            transition: all .2s ease;
            transform: translate(-50%, -100%);
            padding: 12px 16px;
            z-index: 9999;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            min-width: 180px;
        }
        .tooltip-title { font-weight: 800; font-size: 0.85rem; margin-bottom: 8px; color: var(--text-sub); font-family: 'Outfit', sans-serif; }
        .tooltip-line { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; margin-bottom: 4px; }
        .tooltip-color { width: 10px; height: 10px; border-radius: 2px; }
        .tooltip-separator { height: 1px; background: var(--glass-border); margin: 8px 0; }
        .tooltip-value { margin-left: auto; font-weight: 600; font-family: 'Outfit', sans-serif; }

    </style>
</head>
<body x-data="DashboardData({{ groups|json_encode|escape('html_attr') }})">
    <div id="chartjs-tooltip"></div>

    <div class="navbar">
        <div class="navbar-brand">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.21 15.89A10 10 0 1 1 8 2.83M22 12A10 10 0 0 0 12 2v10z"/>
            </svg>
            Cloudflare Multi-View
        </div>
        <div style="display: flex; gap: 1rem; align-items: center;">
            <input
                type="text"
                class="search-bar"
                placeholder="{{ 'dashboard.search_placeholder'|trans }}"
                x-model="searchQuery"
            >
            <div class="custom-dropdown" x-data="{ open: false }">
                <div class="dropdown-trigger" :class="{'open': open}" @click="open = !open" @click.outside="open = false">
                    <span>
                        {% if currentRange == '1h' %}{{ 'dashboard.range.1h'|trans }}{% endif %}
                        {% if currentRange == '3h' %}{{ 'dashboard.range.3h'|trans }}{% endif %}
                        {% if currentRange == '6h' %}{{ 'dashboard.range.6h'|trans }}{% endif %}
                        {% if currentRange == '12h' %}{{ 'dashboard.range.12h'|trans }}{% endif %}
                        {% if currentRange == '24h' %}{{ 'dashboard.range.24h'|trans }}{% endif %}
                        {% if currentRange == '48h' %}{{ 'dashboard.range.48h'|trans }}{% endif %}
                        {% if currentRange == '7d' %}{{ 'dashboard.range.7d'|trans }}{% endif %}
                    </span>
                    <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </div>
                <div class="dropdown-menu" :class="{'show': open}" x-cloak>
                    <div class="dropdown-item {% if currentRange == '1h' %}active{% endif %}" @click="window.location.href='?range=1h'">{{ 'dashboard.range.1h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '3h' %}active{% endif %}" @click="window.location.href='?range=3h'">{{ 'dashboard.range.3h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '6h' %}active{% endif %}" @click="window.location.href='?range=6h'">{{ 'dashboard.range.6h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '12h' %}active{% endif %}" @click="window.location.href='?range=12h'">{{ 'dashboard.range.12h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '24h' %}active{% endif %}" @click="window.location.href='?range=24h'">{{ 'dashboard.range.24h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '48h' %}active{% endif %}" @click="window.location.href='?range=48h'">{{ 'dashboard.range.48h'|trans }}</div>
                    <div class="dropdown-item {% if currentRange == '7d' %}active{% endif %}" @click="window.location.href='?range=7d'">{{ 'dashboard.range.7d'|trans }}</div>
                </div>
            </div>

            <div class="custom-dropdown" x-data="{ open: false }">
                <div class="dropdown-trigger" :class="{'open': open}" @click="open = !open" @click.outside="open = false">
                    <span>
                        <template x-if="refreshInterval === '0'"><span>{{ 'dashboard.refresh.off'|trans }}</span></template>
                        <template x-if="refreshInterval === '1'"><span>{{ 'dashboard.refresh.1m'|trans }}</span></template>
                        <template x-if="refreshInterval === '3'"><span>{{ 'dashboard.refresh.3m'|trans }}</span></template>
                        <template x-if="refreshInterval === '5'"><span>{{ 'dashboard.refresh.5m'|trans }}</span></template>
                        <template x-if="refreshInterval === '10'"><span>{{ 'dashboard.refresh.10m'|trans }}</span></template>
                        <template x-if="refreshInterval === '15'"><span>{{ 'dashboard.refresh.15m'|trans }}</span></template>
                    </span>
                    <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </div>
                <div class="dropdown-menu" :class="{'show': open}" x-cloak>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '0'}" @click="refreshInterval = '0'; open = false">{{ 'dashboard.refresh.off'|trans }}</div>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '1'}" @click="refreshInterval = '1'; open = false">{{ 'dashboard.refresh.1m'|trans }}</div>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '3'}" @click="refreshInterval = '3'; open = false">{{ 'dashboard.refresh.3m'|trans }}</div>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '5'}" @click="refreshInterval = '5'; open = false">{{ 'dashboard.refresh.5m'|trans }}</div>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '10'}" @click="refreshInterval = '10'; open = false">{{ 'dashboard.refresh.10m'|trans }}</div>
                    <div class="dropdown-item" :class="{'active': refreshInterval === '15'}" @click="refreshInterval = '15'; open = false">{{ 'dashboard.refresh.15m'|trans }}</div>
                </div>
            </div>
            <div class="switch-container">
                <span style="font-size: 0.8rem; color: var(--text-sub); font-weight: 500;">{{ 'dashboard.charts_toggle'|trans }}</span>
                <label class="switch">
                    <input type="checkbox" x-model="showCharts">
                    <span class="slider"></span>
                </label>
            </div>
            <div class="switch-container" x-show="showCharts" x-transition x-cloak>
                <span style="font-size: 0.8rem; color: var(--text-sub); font-weight: 500;">{{ 'dashboard.countries_toggle'|trans }}</span>
                <label class="switch">
                    <input type="checkbox" x-model="showCountries">
                    <span class="slider"></span>
                </label>
            </div>
            <div
                class="switch-container"
                @click="blurDomains = !blurDomains"
                style="cursor: pointer;"
                :style="blurDomains ? 'border-color: var(--warning);' : ''"
                title="Toggle domain visibility"
            >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    :style="blurDomains ? 'color: var(--warning)' : 'color: var(--text-sub)'"
                    style="transition: color 0.2s ease;">
                    <path x-show="!blurDomains" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle x-show="!blurDomains" cx="12" cy="12" r="3"/>
                    <path x-show="blurDomains" d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path x-show="blurDomains" d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <line x-show="blurDomains" x1="1" y1="1" x2="23" y2="23"/>
                </svg>
            </div>
            {% if secureDashboard %}
                <a href="{{ path('cf_multi_view_logout') }}" class="switch-container" style="text-decoration: none;" title="Logout">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--danger);">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                </a>
            {% endif %}
        </div>
    </div>

    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
            <div class="date-info" style="margin-bottom: 0;">
                <svg style="vertical-align: -3px; margin-right: 5px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                {{ 'dashboard.data_range'|trans({'%from%': fromDate, '%to%': toDate})|raw }}
                <span style="opacity: 0.6; margin-left: 5px; font-weight: 500;">({{ timezone }})</span>
            </div>

            {% if latestLogDate %}
                <div class="date-info" style="margin-bottom: 0;">
                    <svg style="vertical-align: -3px; margin-right: 5px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <span style="opacity: 0.7;">{{ 'dashboard.last_update'|trans }}:</span>
                    <span style="opacity: 0.6; font-weight: 500; margin-left: 5px;">{{ latestLogDate }}</span>
                </div>
            {% endif %}
        </div>

        <template x-for="(domains, groupName) in filteredGroups" :key="groupName">
            <div class="group-card" x-data="{ expanded: true }">
                <div class="group-header" @click="expanded = !expanded">
                    <div class="group-title">
                        <span x-text="groupName"></span>
                        <span class="badge-count" x-text="Object.keys(domains).length"></span>
                    </div>
                    <svg class="chevron" :class="{'rotated': !expanded}" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="18 15 12 9 6 15"></polyline>
                    </svg>
                </div>

                <div x-show="expanded" x-collapse x-transition @opened="$el.style.overflow = 'visible'" @scroll.window="expanded && ($el.style.overflow = 'visible')">
                    <table>
                        <thead>
                             <tr>
                                <th @click="setSort('domainName')" class="sortable" style="width: 10%;">{{ 'dashboard.table.domain'|trans }} <span x-show="sortCol === 'domainName'" x-text="sortAsc ? '↑' : '↓'" x-cloak></span></th>
                                <th @click="setSort('uniqueVisitors')" class="sortable" style="width: 10%;">{{ 'dashboard.table.visitors'|trans }} <span x-show="sortCol === 'uniqueVisitors'" x-text="sortAsc ? '↑' : '↓'" x-cloak></span></th>
                                <th @click="setSort('totalRequests')" class="sortable" style="width: 10%;">{{ 'dashboard.table.requests'|trans }} <span x-show="sortCol === 'totalRequests'" x-text="sortAsc ? '↑' : '↓'" x-cloak></span></th>
                                <th @click="setSort('bandwidth')" class="sortable" style="width: 10%;">{{ 'dashboard.table.bandwidth'|trans }} <span x-show="sortCol === 'bandwidth'" x-text="sortAsc ? '↑' : '↓'" x-cloak></span></th>
                                <th @click="setSort('threats')" class="sortable" style="width: 10%;">{{ 'dashboard.table.threats'|trans }} <span x-show="sortCol === 'threats'" x-text="sortAsc ? '↑' : '↓'" x-cloak></span></th>
                                <th x-show="showCharts" style="width: 50%;">{{ 'dashboard.table.trends'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="item in getSortedArray(domains)" :key="item.domainName">
                                <tr>
                                    <td class="metric">
                                        <span class="domain-name" :class="{'blurred': blurDomains}" x-text="item.domainName"></span>
                                    </td>
                                    <td class="metric uv" x-text="item.uniqueVisitors.toLocaleString()"></td>
                                    <td class="metric req" x-text="item.totalRequests.toLocaleString()"></td>
                                    <td class="metric" x-text="formatBytes(item.bandwidth)"></td>
                                    <td class="metric threats" x-text="item.threats.toLocaleString()"></td>
                                    <td x-show="showCharts" style="width: 40%; vertical-align: middle;">
                                        <div class="chart-container">
                                            <canvas x-init="$watch('showCharts', val => val && $nextTick(() => initChart($el, item.history))); $watch('showCountries', val => $nextTick(() => initChart($el, item.history))); if(showCharts) $nextTick(() => initChart($el, item.history))"></canvas>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
           </tbody>
                    </table>
                </div>
            </div>
        </template>

        <div x-show="Object.keys(filteredGroups).length === 0" class="empty-state" x-cloak>
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 1rem auto; opacity: 0.5;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <h3>{{ 'dashboard.no_results.title'|trans }}</h3>
            <p style="margin-top: 10px;">{{ 'dashboard.no_results.text'|trans }}</p>
        </div>

        <footer style="margin-top: 4rem; padding-bottom: 3rem; text-align: center; border-top: 1px solid var(--glass-border); padding-top: 2rem;">
            <a href="https://github.com/michallkanak/symfony-cloudflare-multi-view" target="_blank" style="color: var(--text-sub); text-decoration: none; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px; transition: all 0.3s ease; padding: 0.5rem 1rem; border-radius: 99px; background: rgba(255,255,255,0.02); border: 1px solid transparent;" onmouseover="this.style.borderColor='var(--glass-border)'; this.style.color='var(--primary)'; this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.borderColor='transparent'; this.style.color='var(--text-sub)'; this.style.background='rgba(255,255,255,0.02)'">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                <span style="font-weight: 500;">michallkanak/symfony-cloudflare-multi-view</span>
            </a>
        </footer>

    </div>

    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('DashboardData', (initialGroups) => ({
                groups: initialGroups,
                searchQuery: '',
                sortCol: 'domainName',
                sortAsc: true,
                showCharts: localStorage.getItem('cf_show_charts') === 'true',
                showCountries: localStorage.getItem('cf_show_countries') === 'true',
                blurDomains: localStorage.getItem('cf_blur_domains') === 'true',
                refreshInterval: localStorage.getItem('cf_refresh_interval') || '0',
                refreshTimer: null,

                init() {
                    this.$watch('showCharts', val => localStorage.setItem('cf_show_charts', val));
                    this.$watch('blurDomains', val => localStorage.setItem('cf_blur_domains', val));
                    this.$watch('showCountries', val => {
                        localStorage.setItem('cf_show_countries', val);
                        // Trigger chart update
                        window.dispatchEvent(new CustomEvent('resize'));
                    });
                    // Load from URL or localStorage
                    const urlParams = new URLSearchParams(window.location.search);
                    const savedCol = urlParams.get('sort') || localStorage.getItem('cf_sort_col');
                    const savedDir = urlParams.get('dir') || localStorage.getItem('cf_sort_dir');

                    if (savedCol) this.sortCol = savedCol;
                    if (savedDir) this.sortAsc = (savedDir === 'asc');

                    this.startRefreshTimer();
                    this.$watch('refreshInterval', () => this.startRefreshTimer());
                },

                startRefreshTimer() {
                    if (this.refreshTimer) clearInterval(this.refreshTimer);
                    localStorage.setItem('cf_refresh_interval', this.refreshInterval);

                    const minutes = parseInt(this.refreshInterval);
                    if (minutes > 0) {
                        this.refreshTimer = setInterval(() => {
                            window.location.reload();
                        }, minutes * 60 * 1000);
                    }
                },

                setSort(col) {
                    if (this.sortCol === col) {
                        this.sortAsc = !this.sortAsc;
                    } else {
                        this.sortCol = col;
                        this.sortAsc = true;
                    }

                    // Store in localStorage
                    localStorage.setItem('cf_sort_col', this.sortCol);
                    localStorage.setItem('cf_sort_dir', this.sortAsc ? 'asc' : 'desc');

                    // Update URL without reload for consistency
                    const url = new URL(window.location);
                    url.searchParams.set('sort', this.sortCol);
                    url.searchParams.set('dir', this.sortAsc ? 'asc' : 'desc');
                    window.history.replaceState({}, '', url);
                },

                getSortedArray(domainsObj) {
                    const arr = Object.entries(domainsObj).map(([name, stats]) => ({
                        domainName: name,
                        ...stats
                    }));

                    return arr.sort((a, b) => {
                        let va = a[this.sortCol];
                        let vb = b[this.sortCol];

                        if (typeof va === 'string') va = va.toLowerCase();
                        if (typeof vb === 'string') vb = vb.toLowerCase();

                        if (va < vb) return this.sortAsc ? -1 : 1;
                        if (va > vb) return this.sortAsc ? 1 : -1;
                        return 0;
                    });
                },

                get filteredGroups() {
                    if (this.searchQuery.trim() === '') {
                        return this.groups;
                    }

                    const q = this.searchQuery.toLowerCase();
                    const filtered = {};

                    for (const [groupName, domains] of Object.entries(this.groups)) {
                        // Group matches by name
                        if (groupName.toLowerCase().includes(q)) {
                            filtered[groupName] = domains;
                            continue;
                        }

                        // Search inside domains
                        const matchedDomains = {};
                        let hasMatches = false;
                        for (const [domainName, stats] of Object.entries(domains)) {
                            if (domainName.toLowerCase().includes(q)) {
                                matchedDomains[domainName] = stats;
                                hasMatches = true;
                            }
                        }

                        if (hasMatches) {
                            filtered[groupName] = matchedDomains;
                        }
                    }
                    return filtered;
                },

                formatBytes(bytes) {
                    if (bytes === 0) return '0 B';
                    const k = 1024;
                    const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
                },

                initChart(el, history) {
                    if (!history || history.length === 0) return;

                    // Kill existing chart if re-initing on same canvas
                    const existingChart = Chart.getChart(el);
                    if (existingChart) {
                        existingChart.destroy();
                    }

                    setTimeout(() => { // Small timeout to ensure dimensions are calculated
                        new Chart(el, {
                            type: 'line',
                            data: {
                                labels: history.map(h => h.label),
                                datasets: [{
                                    label: 'Requests',
                                    data: history.map(h => h.requests),
                                    borderColor: '#818cf8',
                                    backgroundColor: 'rgba(129, 140, 248, 0.1)',
                                    fill: true,
                                    tension: 0.4,
                                    pointRadius: 1,
                                    borderWidth: 2
                                }, {
                                    label: 'Visitors',
                                    data: history.map(h => h.visitors),
                                    borderColor: '#38bdf8',
                                    backgroundColor: 'transparent',
                                    fill: false,
                                    tension: 0.4,
                                    pointRadius: 1,
                                    borderWidth: 1.5
                                }, {
                                    label: 'Top 1 Country',
                                    isCountry: true,
                                    hidden: !this.showCountries,
                                    data: history.map(h => Object.values(h.topCountries || {})[0] || 0),
                                    borderColor: '#ef4444',
                                    backgroundColor: 'transparent',
                                    fill: false,
                                    tension: 0.4,
                                    pointRadius: 0,
                                    borderWidth: 1.5
                                }, {
                                    label: 'Top 2 Country',
                                    isCountry: true,
                                    hidden: !this.showCountries,
                                    data: history.map(h => Object.values(h.topCountries || {})[1] || 0),
                                    borderColor: '#f59e0b',
                                    backgroundColor: 'transparent',
                                    fill: false,
                                    tension: 0.4,
                                    pointRadius: 0,
                                    borderWidth: 1.5
                                }, {
                                    label: 'Top 3 Country',
                                    isCountry: true,
                                    hidden: !this.showCountries,
                                    data: history.map(h => Object.values(h.topCountries || {})[2] || 0),
                                    borderColor: '#10b981',
                                    backgroundColor: 'transparent',
                                    fill: false,
                                    tension: 0.4,
                                    pointRadius: 0,
                                    borderWidth: 1.5
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                animation: { duration: 400 },
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        enabled: false,
                                        mode: 'index',
                                        intersect: false,
                                        external: function(context) {
                                            const tooltipEl = document.getElementById('chartjs-tooltip');
                                            const tooltipModel = context.tooltip;
                                            if (tooltipModel.opacity === 0) { tooltipEl.style.opacity = 0; return; }
                                            if (tooltipModel.body) {
                                                const titleLines = tooltipModel.title || [];
                                                let innerHtml = '<div class="tooltip-title">' + (titleLines[0] || '') + '</div>';
                                                tooltipModel.body.forEach((body, i) => {
                                                    const colors = tooltipModel.labelColors[i];
                                                    const isCountry = context.chart.data.datasets[i].isCountry;
                                                    if (isCountry && !context.chart.data.datasets[i-1]?.isCountry) {
                                                        innerHtml += '<div class="tooltip-separator"></div>';
                                                    }
                                                    let line = body.lines[0];
                                                    let label = line.split(': ')[0];
                                                    let val = line.split(': ')[1] || '';
                                                    if (isCountry) {
                                                        const dataIndex = tooltipModel.dataPoints[0].dataIndex;
                                                        const countries = history[dataIndex].topCountries || {};
                                                        label = Object.keys(countries)[i - 2] || '??';
                                                    }
                                                    innerHtml += `
                                                        <div class="tooltip-line">
                                                            <div class="tooltip-color" style="background:${colors.borderColor}"></div>
                                                            <span class="tooltip-label">${label}</span>
                                                            <span class="tooltip-value">${val}</span>
                                                        </div>`;
                                                });
                                                tooltipEl.innerHTML = innerHtml;
                                            }
                                            const position = context.chart.canvas.getBoundingClientRect();
                                            tooltipEl.style.opacity = 1;
                                            tooltipEl.style.left = position.left + window.pageXOffset + tooltipModel.caretX + 'px';
                                            tooltipEl.style.top = position.top + window.pageYOffset + tooltipModel.caretY - 10 + 'px';
                                        }
                                    }
                                },
                                layout: {
                                    padding: {
                                        top: 10,
                                        bottom: 0,
                                        left: 0,
                                        right: 0
                                    }
                                },
                                scales: {
                                    x: {
                                        display: true,
                                        grid: { display: false },
                                        ticks: {
                                            maxRotation: 0,
                                            autoSkip: true,
                                            color: '#64748b',
                                            font: { size: 9 }
                                        }
                                    },
                                    y: {
                                        display: true,
                                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                                        ticks: { color: '#64748b', font: { size: 9 } },
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                    }, 50);
                }
            }))
        })
    </script>
</body>
</html>
